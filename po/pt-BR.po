msgstr "\"EldurScrollz\""

#: src/methods-and-traits/deriving.md
msgid "// Debug trait adds support for printing with `{:?}`.\n"
msgstr "// O _trait_ `Debug` adiciona suporte para impressão com `{:?}`.\n"

#: src/methods-and-traits/deriving.md
