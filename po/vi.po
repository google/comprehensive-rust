msgid "Literals"
msgstr "Nguyên Văn Cú Pháp"

#: src/types-and-values/values.md
msgid "Signed integers"
msgstr "Số nguyên có dấu"

#: src/types-and-values/values.md
msgid "`i8`, `i16`, `i32`, `i64`, `i128`, `isize`"
msgstr "`i8`, `i16`, `i32`, `i64`, `i128`, `isize`"

