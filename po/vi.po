msgstr ""
"Xác minh rằng bạn hiểu các điều kiện tiên quyết của bất kỳ chức năng/đặc "
"điểm `unsafe` nào"

#: src/unsafe-deep-dive/introduction/impact-on-workflow.md
msgid "Check that the preconditions are satisfied"
msgstr "Kiểm tra xem các điều kiện tiên quyết có được thỏa mãn không"

#: src/unsafe-deep-dive/introduction/impact-on-workflow.md
msgid "Document your reasoning in safety comments"
msgstr "Ghi lại lý luận của bạn trong phần nhận xét về an toàn"

#: src/unsafe-deep-dive/introduction/impact-on-workflow.md
msgid "Enhanced code review"
msgstr "Đánh giá mã nâng cao"

#: src/unsafe-deep-dive/introduction/impact-on-workflow.md
msgid "Self-review → peer reviewer → unsafe Rust expert (when needed)"
msgstr ""
"Tự đánh giá → người đánh giá ngang hàng → chuyên gia về Rust không an toàn "
