msgid "Derivable: ✅"
msgstr ""

#: src/idiomatic/foundations-api-design/predictable-api/common-traits/debug.md
msgid "When to implement: Almost always"
msgstr ""

#: src/idiomatic/foundations-api-design/predictable-api/common-traits/debug.md
msgid ""
"// pub trait Debug {\n"
"//     fn fmt(&self, f: &mut Formatter<'_>) -> Result<(), Error>;\n"
"// }\n"
msgstr ""

#: src/idiomatic/foundations-api-design/predictable-api/common-traits/debug.md
msgid "\"PlainTextPassword\""
msgstr ""

#: src/idiomatic/foundations-api-design/predictable-api/common-traits/debug.md
msgid "\"hint\""
msgstr ""

#: src/idiomatic/foundations-api-design/predictable-api/common-traits/debug.md
#: src/idiomatic/leveraging-the-type-system/newtype-pattern/semantic-confusion.md
msgid "\"password\""
msgstr ""

#: src/idiomatic/foundations-api-design/predictable-api/common-traits/debug.md
msgid "\"[omitted]\""
msgstr ""

#: src/idiomatic/foundations-api-design/predictable-api/common-traits/debug.md
