#: src/idiomatic/foundations-api-design/meaningful-doc-comments.md
msgid "/// API for the client // ❌ Lacks detail\n"
msgstr ""

#: src/idiomatic/foundations-api-design/meaningful-doc-comments.md
msgid "/// Function from A to B // ❌ Redundant\n"
